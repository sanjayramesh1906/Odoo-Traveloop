generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                 BigInt       @id @default(autoincrement())
  name               String       @db.VarChar(255)
  email              String       @unique @db.VarChar(255)
  hashedPassword     String       @map("hashed_password") @db.VarChar(255)
  photoUrl           String?      @map("photo_url") @db.VarChar(2048)
  languagePreference String       @default("en") @map("language_preference") @db.VarChar(10)
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  tripMembers        TripMember[] @relation("UserTripMembers")
  trips              Trip[]       @relation("UserTrips")

  @@map("users")
}

model City {
  id              BigInt     @id @default(autoincrement())
  name            String     @db.VarChar(255)
  country         String     @db.VarChar(255)
  countryCode     String     @map("country_code") @db.Char(3)
  costIndex       Decimal    @default(0.00) @map("cost_index") @db.Decimal(6, 2)
  popularityScore Decimal    @default(0.00) @map("popularity_score") @db.Decimal(5, 2)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  stops           Stop[]     @relation("CityStops")
  activities      Activity[] @relation("CityActivities")

  @@map("cities")
}

model Activity {
  id              BigInt         @id @default(autoincrement())
  name            String         @db.VarChar(255)
  type            ActivityType
  estimatedCost   Decimal        @default(0.00) @map("estimated_cost") @db.Decimal(10, 2)
  durationMinutes Int            @default(0) @map("duration_minutes")
  description     String?        @db.Text
  imageUrl        String?        @map("image_url") @db.VarChar(2048)
  cityId          BigInt?        @map("city_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  city            City?          @relation("CityActivities", fields: [cityId], references: [id], onDelete: SetNull)
  stopActivities  StopActivity[] @relation("ActivityStopActivities")

  @@map("activities")
}

model Trip {
  id            BigInt        @id @default(autoincrement())
  ownerId       BigInt        @map("owner_id")
  name          String        @db.VarChar(255)
  description   String?       @db.Text
  startDate     DateTime?     @map("start_date") @db.Date
  endDate       DateTime?     @map("end_date") @db.Date
  budget        Decimal       @default(0.00) @db.Decimal(12, 2)
  coverPhotoUrl String?       @map("cover_photo_url") @db.VarChar(2048)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  budgetItems   BudgetItem[]  @relation("TripBudgetItems")
  packingList   PackingList[] @relation("TripPackingList")
  sharedLinks   SharedLink[]  @relation("TripSharedLinks")
  stops         Stop[]        @relation("TripStops")
  tripMembers   TripMember[]  @relation("TripMembers")
  tripNotes     TripNote[]    @relation("TripNotes")
  owner         User          @relation("UserTrips", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId], map: "trips_owner_id_fkey")
  @@map("trips")
}

model Stop {
  id             BigInt         @id @default(autoincrement())
  tripId         BigInt         @map("trip_id")
  cityId         BigInt         @map("city_id")
  arrivalDate    DateTime?      @map("arrival_date") @db.Date
  departureDate  DateTime?      @map("departure_date") @db.Date
  orderIndex     Int            @default(0) @map("order_index")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  stopActivities StopActivity[] @relation("StopStopActivities")
  city           City           @relation("CityStops", fields: [cityId], references: [id], onDelete: Cascade)
  trip           Trip           @relation("TripStops", fields: [tripId], references: [id], onDelete: Cascade)
  tripNotes      TripNote[]     @relation("StopNotes")

  @@unique([tripId, orderIndex], name: "uq_stops_trip_order")
  @@index([cityId], map: "stops_city_id_fkey")
  @@map("stops")
}

model StopActivity {
  id         BigInt   @id @default(autoincrement())
  stopId     BigInt   @map("stop_id")
  activityId BigInt   @map("activity_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  activity   Activity @relation("ActivityStopActivities", fields: [activityId], references: [id], onDelete: Cascade)
  stop       Stop     @relation("StopStopActivities", fields: [stopId], references: [id], onDelete: Cascade)

  @@unique([stopId, activityId], name: "uq_stop_activities_stop_activity")
  @@index([activityId], map: "stop_activities_activity_id_fkey")
  @@map("stop_activities")
}

model BudgetItem {
  id          BigInt         @id @default(autoincrement())
  tripId      BigInt         @map("trip_id")
  category    BudgetCategory
  description String?        @db.VarChar(500)
  amount      Decimal        @default(0.00) @db.Decimal(12, 2)
  date        DateTime?      @db.Date
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  trip        Trip           @relation("TripBudgetItems", fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId], map: "budget_items_trip_id_fkey")
  @@map("budget_items")
}

model PackingList {
  id        BigInt          @id @default(autoincrement())
  tripId    BigInt          @map("trip_id")
  itemName  String          @map("item_name") @db.VarChar(255)
  category  PackingCategory
  isPacked  Boolean         @default(false) @map("is_packed")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  trip      Trip            @relation("TripPackingList", fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId], map: "packing_lists_trip_id_fkey")
  @@map("packing_lists")
}

model TripNote {
  id        BigInt   @id @default(autoincrement())
  tripId    BigInt   @map("trip_id")
  stopId    BigInt?  @map("stop_id")
  title     String?  @db.VarChar(255)
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  stop      Stop?    @relation("StopNotes", fields: [stopId], references: [id])
  trip      Trip     @relation("TripNotes", fields: [tripId], references: [id], onDelete: Cascade)

  @@index([stopId], map: "trip_notes_stop_id_fkey")
  @@index([tripId], map: "trip_notes_trip_id_fkey")
  @@map("trip_notes")
}

model SharedLink {
  id        BigInt    @id @default(autoincrement())
  tripId    BigInt    @map("trip_id")
  token     String    @unique @db.VarChar(128)
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  trip      Trip      @relation("TripSharedLinks", fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId], map: "shared_links_trip_id_fkey")
  @@map("shared_links")
}

model TripMember {
  id        BigInt     @id @default(autoincrement())
  tripId    BigInt     @map("trip_id")
  userId    BigInt     @map("user_id")
  role      MemberRole @default(viewer)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  trip      Trip       @relation("TripMembers", fields: [tripId], references: [id], onDelete: Cascade)
  user      User       @relation("UserTripMembers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId], name: "uq_trip_members_trip_user")
  @@index([userId], map: "trip_members_user_id_fkey")
  @@map("trip_members")
}

enum ActivityType {
  sightseeing
  food
  adventure
  wellness
  shopping
}

enum BudgetCategory {
  Transport
  Stay
  Meal
  Activity
  Miscellaneous
}

enum PackingCategory {
  Clothing
  Documents
  Electronics
  Toiletries
  Miscellaneous
}

enum MemberRole {
  owner
  collaborator
  viewer
}
